{
  "name": "ticket-triage",
  "type": "module",
  "module": "src/index.ts",
  "private": true,
  "scripts": {
    "dev:worker": "wrangler dev",
    "deploy:worker": "wrangler deploy",
    "deploy:worker:dry-run": "wrangler deploy --dry-run",
    "worker:types": "wrangler types src/worker-configuration.d.ts",
    "dev": "mastra dev --dir src",
    "build": "mastra build --dir src",
    "test": "bun test",
    "eval:classifier": "bun src/evals/classifier/run.ts",
    "eval:drafter": "bun src/evals/drafter/grounding.run.ts",
    "eval:reply-quality": "bun src/evals/drafter/reply-quality.run.ts",
    "workflow:smoke": "bun src/evals/workflow/smoke.ts",
    "check-types": "tsc -b",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "tickets:seed": "bun scripts/seed.ts",
    "tickets:reset": "rm -f src/fixtures/tickets.json",
    "mcp:stdio": "bun src/mcp/support-context.stdio.ts",
    "mcp:inspect": "bunx @modelcontextprotocol/inspector bun src/mcp/support-context.stdio.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@cloudflare/workers-types": "^4.20260615.1",
    "@types/bun": "latest",
    "@types/papaparse": "^5.5.2",
    "mastra": "^1.12.2",
    "pino-pretty": "^13.1.3",
    "ultracite": "7.8.1",
    "wrangler": "^4.100.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@mastra/core": "^1.42.0",
    "@mastra/langfuse": "^1.3.4",
    "@mastra/mcp": "^1.10.0",
    "@mastra/observability": "^1.14.1",
    "@t3-oss/env-core": "^0.13.11",
    "hono": "^4.12.25",
    "papaparse": "^5.5.3",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  }
}
